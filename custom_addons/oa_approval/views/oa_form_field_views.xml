<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_oa_form_field_form" model="ir.ui.view">
            <field name="name">oa.form.field.form</field>
            <field name="model">oa.form.field</field>
            <field name="arch" type="xml">
                <form string="Form Field">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="field_type"/>
                                <field name="required"/>
                            </group>
                            <group>
                                <field name="sequence"/>
                                <field name="template_id"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="default_value"
                                       invisible="field_type not in ['char', 'text', 'integer', 'float']"/>
                                <field name="selection_options"
                                       invisible="field_type != 'selection'"
                                       placeholder="選項1,選項2,選項3"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_oa_form_field_list" model="ir.ui.view">
            <field name="name">oa.form.field.list</field>
            <field name="model">oa.form.field</field>
            <field name="arch" type="xml">
                <list string="Form Fields">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="field_type"/>
                    <field name="required" widget="boolean_toggle"/>
                </list>
            </field>
        </record>
    </data>
</odoo>
