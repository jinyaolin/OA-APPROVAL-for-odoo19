<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_oa_form_template_form" model="ir.ui.view">
            <field name="name">oa.form.template.form</field>
            <field name="model">oa.form.template</field>
            <field name="arch" type="xml">
                <form string="Form Template">
                    <header>
                        <button name="action_create_form" string="創建表單" type="object"
                                class="btn-primary" invisible="state != 'published'"/>
                        <button name="action_publish" string="發布" type="object"
                                class="btn-secondary" invisible="[('state', '!=', 'draft')]"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="範本名稱"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="code"/>
                                <field name="category_id"/>
                            </group>
                            <group>
                                <field name="approval_chain_id"/>
                                <field name="version"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <field name="description" placeholder="說明..."/>
                        <notebook>
                            <page string="欄位設定" name="fields">
                                <field name="field_ids">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="name"/>
                                        <field name="code"/>
                                        <field name="field_type"/>
                                        <field name="required"/>
                                        <field name="default_value"/>
                                        <field name="selection_options"
                                               invisible="field_type != 'selection'"/>
                                    </list>
                                </field>
                            </page>
                            <page string="統計資訊" name="stats">
                                <group>
                                    <group>
                                        <field name="instance_count"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_oa_form_template_list" model="ir.ui.view">
            <field name="name">oa.form.template.list</field>
            <field name="model">oa.form.template</field>
            <field name="arch" type="xml">
                <list string="Form Templates" multi_edit="1">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="category_id"/>
                    <field name="instance_count"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'published'"
                           decoration-info="state == 'draft'"/>
                    <field name="active" widget="boolean_toggle"/>
                    <button name="action_create_form" string="創建表單" type="object"
                            icon="fa-plus" class="btn-link"
                            invisible="state != 'published'"/>
                </list>
            </field>
        </record>

        <record id="view_oa_form_template_search" model="ir.ui.view">
            <field name="name">oa.form.template.search</field>
            <field name="model">oa.form.template</field>
            <field name="arch" type="xml">
                <search string="Form Templates">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="category_id"/>
                    <filter string="草稿" name="draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="已發布" name="published" domain="[('state', '=', 'published')]"/>
                    <group>
                        <filter string="分類" name="group_category" domain="[]" context="{'group_by': 'category_id'}"/>
                        <filter string="狀態" name="group_state" domain="[]" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_oa_form_template" model="ir.actions.act_window">
            <field name="name">表單範本</field>
            <field name="res_model">oa.form.template</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    建立第一個表單範本
                </p>
            </field>
        </record>
    </data>
</odoo>
