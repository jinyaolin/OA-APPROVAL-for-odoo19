<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Approval Chain Form View -->
        <record id="view_oa_approval_chain_form" model="ir.ui.view">
            <field name="name">oa.approval.chain.form</field>
            <field name="model">oa.approval.chain</field>
            <field name="arch" type="xml">
                <form string="審核鏈">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="審核鏈名稱"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="code"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="審核步驟" name="steps">
                                <field name="step_ids">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="name"/>
                                        <field name="approver_type"/>
                                        <field name="specific_approver_id"
                                               attrs="{'required': [('approver_type', '=', 'specific')], 'invisible': [('approver_type', '!=', 'specific')]}"/>
                                        <field name="timeout_hours"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Approval Chain List View -->
        <record id="view_oa_approval_chain_list" model="ir.ui.view">
            <field name="name">oa.approval.chain.list</field>
            <field name="model">oa.approval.chain</field>
            <field name="arch" type="xml">
                <list string="審核鏈">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="step_ids" widget="many2many_tags"/>
                </list>
            </field>
        </record>

        <!-- Approval Action: Action -->
        <record id="action_oa_approval_chain" model="ir.actions.act_window">
            <field name="name">審核鏈</field>
            <field name="res_model">oa.approval.chain</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    建立第一個審核鏈
                </p>
            </field>
        </record>

        <!-- Approval Record Views (for viewing approval history) -->
        <record id="view_oa_approval_record_list" model="ir.ui.view">
            <field name="name">oa.approval.record.list</field>
            <field name="model">oa.approval.record</field>
            <field name="arch" type="xml">
                <list string="審核記錄">
                    <field name="instance_id"/>
                    <field name="step_id"/>
                    <field name="approver_id"/>
                    <field name="action"/>
                    <field name="create_date"/>
                </list>
            </field>
        </record>

        <record id="view_oa_approval_record_form" model="ir.ui.view">
            <field name="name">oa.approval.record.form</field>
            <field name="model">oa.approval.record</field>
            <field name="arch" type="xml">
                <form string="審核記錄">
                    <sheet>
                        <group>
                            <group>
                                <field name="instance_id" readonly="1"/>
                                <field name="step_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="approver_id" readonly="1"/>
                                <field name="action" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="comment" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
