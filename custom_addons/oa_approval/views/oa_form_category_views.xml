<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_oa_form_category_form" model="ir.ui.view">
            <field name="name">oa.form.category.form</field>
            <field name="model">oa.form.category</field>
            <field name="arch" type="xml">
                <form string="Form Category">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="分類名稱"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="code"/>
                                <field name="parent_id"/>
                            </group>
                            <group>
                                <field name="sequence"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Available Templates" name="templates">
                                <field name="template_ids" readonly="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="approval_chain_id"/>
                                        <field name="instance_count"/>
                                        <button name="action_create_form" string="Create Form" type="object"
                                                icon="fa-plus" class="btn-primary"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_oa_form_category_list" model="ir.ui.view">
            <field name="name">oa.form.category.list</field>
            <field name="model">oa.form.category</field>
            <field name="arch" type="xml">
                <list string="Form Categories">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="parent_id"/>
                </list>
            </field>
        </record>

        <record id="view_oa_form_category_search" model="ir.ui.view">
            <field name="name">oa.form.category.search</field>
            <field name="model">oa.form.category</field>
            <field name="arch" type="xml">
                <search string="Form Categories">
                    <field name="name"/>
                    <field name="code"/>
                    <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

        <record id="action_oa_form_category" model="ir.actions.act_window">
            <field name="name">Form Categories</field>
            <field name="res_model">oa.form.category</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
