<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Wizard Form View -->
        <record id="oa_form_template_select_wizard_view_form" model="ir.ui.view">
            <field name="name">oa.form.template.select.wizard.form</field>
            <field name="model">oa.form.template.select.wizard</field>
            <field name="arch" type="xml">
                <form string="選擇表單範本">
                    <sheet>
                        <group>
                            <group>
                                <field name="category_id" placeholder="選擇表單分類..."/>
                                <field name="template_id" placeholder="選擇表單範本..."/>
                            </group>
                            <group>
                                <div class="alert alert-info" role="alert" invisible="not category_id">
                                    <strong>提示：</strong>
                                    <span>已選擇「</span>
                                    <field name="category_id" readonly="1" nolabel="1"/>
                                    <span>」分類，請選擇要使用的表單範本。</span>
                                </div>
                            </group>
                        </group>
                        <footer>
                            <button name="action_create_form" string="創建表單" type="object" class="btn-primary"/>
                            <button string="取消" class="btn-secondary" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Wizard Action -->
        <record id="oa_form_template_select_wizard_action" model="ir.actions.act_window">
            <field name="name">選擇表單範本</field>
            <field name="res_model">oa.form.template.select.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- Form Fill Wizard View -->
        <record id="oa_form_fill_wizard_view_form" model="ir.ui.view">
            <field name="name">oa.form.fill.wizard.form</field>
            <field name="model">oa.form.fill.wizard</field>
            <field name="arch" type="xml">
                <form string="填寫表單內容">
                    <sheet>
                        <group>
                            <group>
                                <field name="template_id" readonly="1"/>
                                <field name="applicant_id" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="表單內容" name="content">
                                <group>
                                    <group string="欄位 1" invisible="not field_1_label">
                                        <h4><field name="field_1_label" readonly="1" nolabel="1"/></h4>
                                        <field name="field_1_type" invisible="1" nolabel="1"/>
                                        <field name="field_1_id" invisible="1" nolabel="1"/>
                                        <!-- Char 類型 -->
                                        <field name="field_1_char" nolabel="1"
                                               placeholder="請輸入內容"
                                               invisible="field_1_type != 'char'"/>
                                        <!-- Selection 類型 -->
                                        <field name="field_1_selection_id" nolabel="1"
                                               placeholder="請選擇選項"
                                               invisible="field_1_type != 'selection'"/>
                                        <field name="field_1_text" placeholder="請輸入內容" nolabel="1"
                                               invisible="field_1_type != 'text'"/>
                                        <field name="field_1_integer" nolabel="1"
                                               invisible="field_1_type != 'integer'"/>
                                        <field name="field_1_float" nolabel="1"
                                               invisible="field_1_type != 'float'"/>
                                        <field name="field_1_date" nolabel="1"
                                               invisible="field_1_type != 'date'"/>
                                        <field name="field_1_datetime" nolabel="1"
                                               invisible="field_1_type != 'datetime'"/>
                                        <field name="field_1_employee_id" nolabel="1"
                                               invisible="field_1_type != 'employee'"/>
                                        <field name="field_1_department_id" nolabel="1"
                                               invisible="field_1_type != 'department'"/>
                                        <field name="field_1_file" nolabel="1"
                                               invisible="field_1_type != 'file'"/>
                                        <field name="field_1_filename" invisible="1" nolabel="1"/>
                                    </group>

                                    <group string="欄位 2" invisible="not field_2_label">
