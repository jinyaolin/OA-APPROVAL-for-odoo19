                                        <field name="field_5_filename" invisible="1" nolabel="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                        <footer>
                            <button name="action_create_form" string="創建表單" type="object" class="btn-primary"/>
                            <button string="取消" class="btn-secondary" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Form Fill Wizard Action -->
        <record id="oa_form_fill_wizard_action" model="ir.actions.act_window">
