<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- 用戶只能看到/修改自己的表單（草稿狀態） -->
        <record id="oa_form_instance_user_rule" model="ir.rule">
            <field name="name">OA: 用戶只能看到自己的表單</field>
            <field name="model_id" ref="model_oa_form_instance"/>
            <field name="domain_force">[('applicant_id', '=', user.employee_id.id)]</field>
            <field name="groups" eval="[(4, ref('oa_approval.group_oa_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- 審核人只能看到待審核的表單 -->
        <record id="oa_form_instance_approver_rule" model="ir.rule">
            <field name="name">OA: 審核人只能看到待審核的表單</field>
            <field name="model_id" ref="model_oa_form_instance"/>
            <field name="domain_force">[('state', '=', 'pending')]</field>
            <field name="groups" eval="[(4, ref('oa_approval.group_oa_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
