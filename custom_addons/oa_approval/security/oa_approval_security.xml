<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- 用戶組 -->
        <record id="group_oa_user" model="res.groups">
            <field name="name">OA 用戶</field>
            <field name="sequence">10</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_oa_manager" model="res.groups">
            <field name="name">OA 經理</field>
            <field name="sequence">20</field>
            <field name="implied_ids" eval="[(4, ref('oa_approval.group_oa_user'))]"/>
        </record>

        <record id="group_oa_admin" model="res.groups">
            <field name="name">OA 管理員</field>
            <field name="sequence">30</field>
            <field name="comment">OA 系統管理員</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('base.group_system'))]"/>
        </record>

    </data>
</odoo>
